# Copy to .env and fill in real values (never commit .env).
# DB_HOST is localhost when using an SSH tunnel to a remote MySQL server.
DB_HOST=localhost
DB_PORT=3307
DB_REMOTE_HOST=your.remote.db.host
DB_USER=your_db_user
DB_PASSWORD=your_password_here
DB_NAME=moome
SECRET_KEY=generate-a-long-random-secret-key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — SSH tunnel for start.sh (defaults shown)
# SSH_TUNNEL_KEY=$HOME/.ssh/your_tunnel_key

# Password reset
FRONTEND_URL=http://localhost:5173
RESET_TOKEN_EXPIRE_MINUTES=60

# Email (optional — reset links print to server console when SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@moome.rw
